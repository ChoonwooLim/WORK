# ============================================
# RemoteAGT Configuration
# ============================================

# Server
PORT=4100
NODE_ENV=development

# ============================================
# Telegram Bot (Required for Phase 1)
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id_here

# ============================================
# Database (Shared with Orbitron)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/orbitron

# ============================================
# Redis (Task Queue)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Orbitron API Integration
# ============================================
ORBITRON_API_URL=http://localhost:4000/api
ORBITRON_API_KEY=

# ============================================
# Security
# ============================================
JWT_SECRET=change_me_to_random_string
ENCRYPTION_KEY=change_me_32_char_aes256_key_!!

# ============================================
# Antigravity Bridge
# ============================================
AGT_WORKSPACE_PATH=/home/stevenlim/WORK

# ============================================
# Monitoring
# ============================================
METRIC_COLLECT_INTERVAL=30000
ALERT_COOLDOWN=300000
